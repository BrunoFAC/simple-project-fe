{
	"name": "feature-flags",
	"private": true,
	"version": "1.0.0",
	"type": "module",
	"scripts": {
		"start": "vite",
		"build": "tsc -b && vite build",
		"gen-api": "npx swagger-typescript-api generate -p http://localhost:5894/api-docs.json -o ./src/apiClient --modular",
		"clean-install": "rimraf node_modules package-lock.json && npm cache clean --force && npm i && node --max-old-space-size=8192 scripts/shaihulud-check.mjs --update --check --output blocklist.json --fail-on-hit",
		"spell-check": "cspell \"./src/**/*.{js,jsx,ts,tsx}\"",
		"lint": "eslint \"./src/**/*.{ts,tsx}\"",
		"lint-errors": "eslint --quiet \"./src/**/*.{js,jsx,ts,tsx}\"",
		"lint-dir": "eslint --",
		"lint-fix": "eslint --fix \"./src/**/*.{ts,tsx}\"",
		"prettier-write": "prettier --write \"./src/**/*.{js,jsx,ts,tsx,json}\"",
		"pre-commit": "npm run prettier-write && npm run lint-errors && npm run spell-check",
		"pre-push": "npm run test-coverage & npm run build",
		"preview": "vite preview"
	},
	"dependencies": {
		"@emotion/css": "11.13.5",
		"@emotion/react": "11.14.0",
		"@emotion/styled": "11.14.0",
		"@fontsource/roboto": "5.2.10",
		"@hookform/resolvers": "5.2.2",
		"@mui/icons-material": "7.3.9",
		"@mui/material": "7.3.9",
		"@tanstack/react-query": "5.90.21",
		"axios": "1.9.0",
		"dayjs": "1.11.13",
		"i18next": "25.2.1",
		"i18next-http-backend": "3.0.2",
		"notistack": "3.0.2",
		"react": "19.2.3",
		"react-dom": "19.2.3",
		"react-error-boundary": "6.1.1",
		"react-hook-form": "7.71.2",
		"react-i18next": "15.5.3",
		"react-router-dom": "7.6.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@eslint/js": "9.25.0",
		"@testing-library/react": "16.3.0",
		"@testing-library/user-event": "14.6.1",
		"@trivago/prettier-plugin-sort-imports": "5.2.2",
		"@types/node": "24.0.1",
		"@types/react": "19.2.3",
		"@types/react-dom": "19.2.3",
		"@vitejs/plugin-react": "4.4.1",
		"cspell": "5.18.5",
		"cspell-dict-en_us": "1.3.7",
		"cspell-dict-en-gb": "1.2.6",
		"cspell-dict-lorem-ipsum": "1.1.2",
		"eslint": "9.28.0",
		"eslint-plugin-react-hooks": "5.2.0",
		"eslint-plugin-react-refresh": "0.4.19",
		"globals": "16.0.0",
		"prettier": "3.5.3",
		"typescript": "5.8.3",
		"typescript-eslint": "8.30.1",
		"vite": "6.3.5"
	}
}
